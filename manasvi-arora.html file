<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manasvi Arora Prediction – Asia's No.1 Lady Tipper</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0E0A12;
    --bg2: #160E1E;
    --rose: #E8739A;
    --rose-light: #F5A8C4;
    --rose-dark: #A84870;
    --gold: #E8C96A;
    --crimson: #C0394B;
    --white: #FAF0F4;
    --muted: #9080A0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
  }

  /* Ambient blobs */
  body::before {
    content: '';
    position: fixed;
    width: 600px; height: 600px;
    top: -150px; left: -150px;
    background: radial-gradient(circle, rgba(232,115,154,0.12) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
    animation: drift1 8s ease-in-out infinite alternate;
  }
  body::after {
    content: '';
    position: fixed;
    width: 500px; height: 500px;
    bottom: -100px; right: -100px;
    background: radial-gradient(circle, rgba(192,57,75,0.1) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
    animation: drift2 10s ease-in-out infinite alternate;
  }
  @keyframes drift1 { from { transform: translate(0,0); } to { transform: translate(40px,30px); } }
  @keyframes drift2 { from { transform: translate(0,0); } to { transform: translate(-30px,-40px); } }

  /* HERO */
  .hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 70px 24px 50px;
    text-align: center;
  }

  /* Decorative petal rings */
  .ring-wrap {
    position: relative;
    margin-bottom: 32px;
    animation: popIn 1s cubic-bezier(0.16,1,0.3,1) both;
  }

  .ring-wrap::before, .ring-wrap::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    inset: -14px;
    border: 1px solid rgba(232,115,154,0.3);
    animation: rotateSlow 12s linear infinite;
  }
  .ring-wrap::after {
    inset: -26px;
    border-color: rgba(232,201,106,0.15);
    border-style: dashed;
    animation-direction: reverse;
    animation-duration: 18s;
  }

  @keyframes rotateSlow { to { transform: rotate(360deg); } }

  .profile-img {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    border: 2.5px solid var(--rose);
    box-shadow:
      0 0 0 4px rgba(232,115,154,0.15),
      0 0 50px rgba(232,115,154,0.35),
      0 0 100px rgba(232,115,154,0.12);
    position: relative;
    z-index: 1;
    display: block;
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0.8); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* Lucky star float */
  .lucky-icon {
    position: absolute;
    top: -8px; right: -8px;
    font-size: 22px;
    animation: starBounce 2s ease-in-out infinite;
    z-index: 2;
    filter: drop-shadow(0 0 8px rgba(232,201,106,0.8));
  }
  @keyframes starBounce {
    0%,100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-6px) rotate(15deg); }
  }

  .eyebrow {
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 12px;
    animation: fadeUp 1s 0.4s both;
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: center;
  }
  .eyebrow::before, .eyebrow::after {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--rose);
    opacity: 0.5;
  }

  .hero-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(38px, 11vw, 68px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.5px;
    animation: fadeUp 1s 0.55s both;
    margin-bottom: 6px;
  }

  .hero-name .accent {
    background: linear-gradient(135deg, var(--rose-light), var(--rose), var(--rose-dark));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .hero-name .white { color: var(--white); }

  .hero-sub {
    font-size: clamp(12px, 3.5vw, 14px);
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 8px;
    animation: fadeUp 1s 0.65s both;
  }

  .hero-tagline-box {
    margin: 28px auto 0;
    max-width: 460px;
    background: linear-gradient(135deg, rgba(232,115,154,0.08), rgba(22,14,30,0.6));
    border: 1px solid rgba(232,115,154,0.2);
    border-radius: 2px;
    padding: 20px 28px;
    animation: fadeUp 1s 0.75s both;
  }

  .hero-tagline-box p {
    font-size: 15px;
    font-weight: 400;
    color: rgba(250,240,244,0.72);
    line-height: 1.75;
  }

  .hero-tagline-box strong {
    color: var(--rose-light);
    font-weight: 600;
  }

  .divider-rose {
    width: 60px; height: 1px;
    background: linear-gradient(90deg, transparent, var(--rose), transparent);
    margin: 30px auto;
    animation: fadeUp 1s 0.8s both;
  }

  /* TG BUTTON */
  .tg-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: linear-gradient(135deg, #229ED9, #1580b8, #0e6999);
    color: #fff;
    text-decoration: none;
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 18px 42px;
    border-radius: 3px;
    position: relative;
    overflow: hidden;
    animation: fadeUp 1s 0.95s both;
    box-shadow: 0 8px 30px rgba(34,158,217,0.4), 0 0 60px rgba(34,158,217,0.12);
    transition: transform 0.25s, box-shadow 0.25s;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .tg-btn::before {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left 0.5s;
  }
  .tg-btn:hover::before { left: 100%; }
  .tg-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(34,158,217,0.5), 0 0 80px rgba(34,158,217,0.18);
  }
  .tg-icon { width: 24px; height: 24px; flex-shrink: 0; }

  .sub-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 18px;
    background: rgba(232,115,154,0.08);
    border: 1px solid rgba(232,115,154,0.2);
    border-radius: 50px;
    padding: 6px 16px;
    font-size: 12px;
    letter-spacing: 1.5px;
    color: var(--muted);
    text-transform: uppercase;
    animation: fadeUp 1s 1.05s both;
  }
  .sub-pill .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--rose);
    animation: blink 1.5s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* FEATURES */
  .features {
    position: relative; z-index: 1;
    padding: 50px 24px 60px;
    max-width: 860px;
    margin: 0 auto;
  }

  .section-label {
    text-align: center;
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 36px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 14px;
  }

  .card {
    background: linear-gradient(160deg, rgba(22,14,30,0.9), rgba(14,10,18,0.95));
    border: 1px solid rgba(232,115,154,0.15);
    border-bottom: 2px solid var(--rose-dark);
    padding: 26px 22px;
    border-radius: 3px;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    position: relative;
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--rose), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(232,115,154,0.12); border-color: rgba(232,115,154,0.35); }
  .card:hover::before { opacity: 1; }

  .card-emoji { font-size: 26px; margin-bottom: 12px; display: block; }
  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    color: var(--rose-light);
    margin-bottom: 7px;
    font-weight: 700;
  }
  .card-desc {
    font-size: 13px;
    color: rgba(250,240,244,0.55);
    line-height: 1.65;
  }

  /* DISCLAIMER */
  .disclaimer {
    position: relative; z-index: 1;
    max-width: 560px;
    margin: 0 auto 40px;
    padding: 18px 26px;
    border: 1px solid rgba(232,115,154,0.12);
    border-left: 3px solid var(--rose-dark);
    background: rgba(22,14,30,0.7);
    font-size: 12px;
    color: var(--muted);
    line-height: 1.8;
    text-align: center;
  }

  /* FOOTER */
  footer {
    position: relative; z-index: 1;
    padding: 28px 24px;
    text-align: center;
    border-top: 1px solid rgba(232,115,154,0.1);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.5px;
  }
  footer a { color: var(--rose); text-decoration: none; }

  @media (max-width: 480px) {
    .profile-img { width: 120px; height: 120px; }
    .cards { grid-template-columns: 1fr 1fr; }
    .tg-btn { padding: 16px 26px; font-size: 14px; }
  }
</style>
</head>
